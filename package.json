{
  "name": "@stackbilt/audit-chain",
  "version": "0.1.0",
  "description": "Tamper-evident audit trail for Cloudflare Workers. SHA-256 hash chaining with R2 immutability and D1 indexing.",
  "author": "Kurt Overmier <kurt@stackbilt.dev>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stackbilt-dev/audit-chain.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "schema.sql",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250320.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "audit",
    "audit-trail",
    "hash-chain",
    "tamper-evident",
    "r2",
    "d1",
    "compliance"
  ],
  "engines": {
    "node": ">=18.0.0"
  }
}
